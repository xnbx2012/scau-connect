# SCAU aTrust 连接配置示例
# 复制此文件为 .env 并填入真实账号密码

# ===== 必填 =====
SCAU_USERNAME=你的学号或工号
SCAU_PASSWORD=你的密码

# ===== 可选（已有默认值）=====
# SCAU_SERVER=vpn.scau.edu.cn
# SCAU_PORT=443
# SCAU_HTTP_PROXY_PORT=1081
# SCAU_SOCKS5_PROXY_PORT=1080
# SCAU_ENABLE_HTTP_PROXY=true
# SCAU_ENABLE_SOCKS5_PROXY=false   # 实验性：仅 80 端口的 HTTP 请求可用
# SCAU_SESSION_FILE=.session.json
# SCAU_AUTO_RECONNECT=true

# ===== 调试选项 =====
# SCAU_DEBUG=1
# SCAU_HEADLESS_BROWSER=true  # false = 显示浏览器窗口
